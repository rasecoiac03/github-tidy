#!/usr/bin/env bash

GITHUB_API=${GITHUB_API:-https://api.github.com}
INACTIVITY_DAYS=${INACTIVITY_DAYS:-90}

RED='\033[0;31m'
YELLOW='\033[0;33m'
WHITE='\033[1;37m'
GRAY='\033[1;30m'
NC='\033[0m' # No Color

usage() {
    echo "Usage: $(basename "$0") <repo>"
    echo ""
    echo "  repo can be:"
    echo "    - owner/repo"
    echo "    - https://github.com/owner/repo"
    echo "    - git@github.com:owner/repo.git"
    echo "    - /path/to/local/repo  (reads origin remote to resolve owner/repo)"
    echo "    - .                      (current directory)"
    echo ""
    echo "  Branch checks always use the GitHub API (requires GH_TOKEN)."
    echo ""
    echo "  Environment:"
    echo "    GH_TOKEN           GitHub token (required)"
    echo "    INACTIVITY_DAYS    Threshold in days (default: 90)"
    exit 1
}

print_separator() {
    echo -e "${GRAY}============================================================${NC}"
}

# Prints owner/repo from a GitHub remote URL.
parse_github_remote() {
    local url=$1

    if [[ "$url" =~ ^https?://github\.com/([^/]+)/([^/.]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
        return 0
    fi

    if [[ "$url" =~ ^git@github\.com:([^/]+)/([^/.]+) ]]; then
        echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
        return 0
    fi

    return 1
}

# Resolves input to owner/repo (GitHub only).
resolve_repo() {
    local input=$1
    local path
    local remote_url

    if [ -z "$input" ]; then
        return 1
    fi

    if parsed=$(parse_github_remote "$input"); then
        echo "$parsed"
        return 0
    fi

    if [[ "$input" =~ ^[^/]+/[^/]+$ ]] && [[ "$input" != *://* ]] && [[ "$input" != *@* ]]; then
        echo "$input"
        return 0
    fi

    if [ -e "$input" ] || [ "$input" = "." ]; then
        path=$(cd "$input" 2>/dev/null && pwd) || return 1
        if ! git -C "$path" rev-parse --git-dir &>/dev/null; then
            return 1
        fi
        remote_url=$(git -C "$path" remote get-url origin 2>/dev/null) || return 1
        if parsed=$(parse_github_remote "$remote_url"); then
            echo "$parsed"
            return 0
        fi
        echo "origin remote is not a github.com URL: ${remote_url}" >&2
        return 1
    fi

    return 1
}

days_since_iso() {
    local iso_date=$1
    local then
    if date -d "$iso_date" &>/dev/null 2>&1; then
        then=$(date -d "$iso_date" '+%s')
    else
        then=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$iso_date" '+%s' 2>/dev/null) \
            || then=$(date -j -f "%Y-%m-%dT%H:%M:%S%z" "$iso_date" '+%s')
    fi
    echo $(( ($(date '+%s') - then) / 86400 ))
}

check_branch_open_prs() {
    local branch=$1
    local owner=${REPO%%/*}
    local prs
    local count

    prs=$(curl -sG -H "Authorization: token $GH_TOKEN" \
        "${GITHUB_API}/repos/${REPO}/pulls" \
        --data-urlencode "state=open" \
        --data-urlencode "head=${owner}:${branch}")

    if ! echo "$prs" | jq -e 'type == "array"' >/dev/null 2>&1; then
        echo "  could not check open PRs for this branch" >&2
        return 1
    fi

    count=$(echo "$prs" | jq 'length')
    if [ "${count:-0}" -gt 0 ]; then
        echo -e "${YELLOW}open PR(s) for this branch:${NC}"
        echo "$prs" | jq -r '.[] | "  #\(.number): \(.html_url)"'
        return 0
    fi
    echo "  no open PR for this branch"
    return 1
}

check_branch() {
    local branches_endpoint=$1
    local branch=$2
    local last_commit_date
    local days

    last_commit_date=$(curl -H "Authorization: token $GH_TOKEN" -sL "${branches_endpoint}/${branch}" | jq -r '.commit.commit.committer.date')
    days=$(days_since_iso "$last_commit_date")
    print_separator
    echo -e "checking ${WHITE}${branch}${NC}"
    if [ "$days" -gt "$INACTIVITY_DAYS" ]; then
        echo -e "${RED}inactive for more than ${INACTIVITY_DAYS} days (${days} days)${NC}"
        check_branch_open_prs "$branch"
        return 1
    fi
    echo -e "OK (${days} days)"
    return 0
}

read_branches() {
    local branches_endpoint=$1
    local page=$2
    local branches
    local branches_length
    local branch

    branches=$(curl -H "Authorization: token $GH_TOKEN" -sL "${branches_endpoint}?page=${page}" | jq -r '.[].name')
    branches_length=$(echo "$branches" | tr -d '\n' | wc -m | tr -d ' ')
    if [ "$branches_length" -eq 0 ]; then
        print_separator
        echo "there is no more branches to check"
        return 0
    fi

    for branch in $branches; do
        check_branch "$branches_endpoint" "$branch"
    done

    page=$((page + 1))
    return $page
}

if [ -z "$GH_TOKEN" ]; then
    echo "GH_TOKEN is required" >&2
    exit 1
fi

REPO=$(resolve_repo "$1")
if [ $? -ne 0 ] || [ -z "$REPO" ]; then
    usage
fi

echo "checking branches via GitHub API: ${REPO}"

page=1
while [ "$page" -gt 0 ]; do
    read_branches "$GITHUB_API/repos/$REPO/branches" "$page"
    page=$?
done
